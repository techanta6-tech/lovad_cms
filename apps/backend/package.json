{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "yarn prisma:generate && node ../../node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node ../../node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "yarn prisma:generate && node ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:dev:nogen": "node ../../node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate --schema=prisma/lcms.prisma && node ../../node_modules/prisma/build/index.js generate --schema=prisma/dvms.prisma && node ../../node_modules/prisma/build/index.js generate --schema=prisma/cms_webserver.prisma",
    "prisma:studio:lcms": "node ../../node_modules/prisma/build/index.js studio --schema=prisma/lcms.prisma",
    "prisma:studio:dvms": "node ../../node_modules/prisma/build/index.js studio --schema=prisma/dvms.prisma",
    "prisma:studio:cms": "node ../../node_modules/prisma/build/index.js studio --schema=prisma/cms_webserver.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@prisma/client": "^5.10.0",
    "sharp": "^0.33.5",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.33.5",
    "@img/sharp-linuxmusl-x64": "^0.33.5",
    "@img/sharp-win32-x64": "^0.33.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.0"
  }
}
