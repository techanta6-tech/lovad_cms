{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "yarn prisma:generate && nest build",
    "start": "nest start",
    "start:dev": "yarn prisma:generate && nest start --watch",
    "start:dev:nogen": "nest start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate --schema=prisma/lcms.prisma && prisma generate --schema=prisma/dvms.prisma && prisma generate --schema=prisma/cms_webserver.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@prisma/client": "^5.10.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.0"
  }
}
