generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/dvms"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:@localhost:5433/dvms_server?connect_timeout=15"
}

model camera_cfg {
  id            String    @id @db.VarChar(40)
  name          String?   @db.VarChar(64)
  search_tag    String?   @db.VarChar(256)
  cfg_data      Bytes?
  user_id_owner String?   @db.VarChar(40)
  time_created  DateTime? @db.Timestamp(6)
  time_modified DateTime? @db.Timestamp(6)

  @@index([user_id_owner], type: Hash)
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
/// This model contains an index with non-default null sort order and requires additional setup for migrations. Visit https://pris.ly/d/default-index-null-ordering for more info.
model camera_storage_hour_parent {
  id             String    @default(dbgenerated("uuid_generate_v1()")) @db.Uuid
  partition_path String?   @db.VarChar(8)
  camera_id      String?   @db.VarChar(40)
  use_disk_mb    Float?    @db.Real
  time_start     DateTime? @db.Timestamp(6)
  time_end       DateTime? @db.Timestamp(6)
  total_dur      Int?      @db.SmallInt
  lost_dur       Int?      @db.SmallInt
  partition_key  Int?

  @@index([camera_id], type: Hash)
  @@index([id], type: Hash)
  @@index([time_start(sort: Desc)])
  @@ignore
}

model camera_storage_total {
  partition_path String    @db.VarChar(8)
  camera_id      String    @db.VarChar(40)
  use_disk_mb    Float?    @db.Real
  time_start     DateTime? @db.Timestamp(6)
  time_end       DateTime? @db.Timestamp(6)
  total_dur      Int?
  lost_dur       Int?

  @@id([partition_path, camera_id], map: "camera_storage_total_pk")
}

model channel_cfg {
  id                String    @id @db.VarChar(40)
  name              String?   @db.VarChar(64)
  camera_mapping_id String?   @db.VarChar(64)
  search_tag        String?   @db.VarChar(256)
  cfg_data          Bytes?
  user_id_owner     String?   @db.VarChar(40)
  time_created      DateTime? @db.Timestamp(6)
  time_modified     DateTime? @db.Timestamp(6)

  @@index([camera_mapping_id], type: Hash)
  @@index([user_id_owner], type: Hash)
}

