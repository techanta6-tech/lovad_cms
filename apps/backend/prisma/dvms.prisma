  channel_id    String?   @db.VarChar(40)
  partition_key Int?

  @@index([channel_id], type: Hash)
  @@index([id], type: Hash)
  @@ignore
}

model device_owner_cfg {
  id            String    @id @db.VarChar(128)
  name          String?   @db.VarChar(256)
  time_created  DateTime? @db.Timestamp(6)
  time_modified DateTime? @db.Timestamp(6)
